{
  "name": "southbag-terminal",
  "productName": "Southbag Terminal",
  "version": "1.0.0",
  "description": "Southbag's official enterprise terminal emulator.",
  "main": "main/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w node-pty",
    "dist": "electron-builder"
  },
  "author": "Southbag Global Enterprise Network",
  "license": "Unlicense",
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "cc.southbag.terminal",
    "productName": "Southbag Terminal",
    "files": [
      "main/**",
      "renderer/**",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
